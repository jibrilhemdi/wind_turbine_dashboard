# ===========================================================================
# YORK WIND TURBINE - ANALYSIS SCRIPT
# Performs performance analysis on turbine data
# ===========================================================================
# Install required packages if not already installed (optional)
required_packages <- c("dplyr", "ggplot2", "lubridate", "tidyr", "DBI",
"RPostgres", "yaml", "scales", "patchwork", "knitr")
new_packages <- required_packages[!(required_packages %in% installed.packages()[, "Package"])]
if (length(new_packages)) install.packages(new_packages)
# Load libraries
library(dplyr)
library(ggplot2)
library(lubridate)
library(tidyr)
library(scales)
library(patchwork)
library(DBI)
library(RPostgres)
library(yaml)
# Source the load_data.R script
source("load_data.R")
shiny::runApp()
ratio
runApp()
shiny::runApp()
shiny::runApp()
